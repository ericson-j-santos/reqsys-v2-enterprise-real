{
  "schema_version": "1.0.1",
  "mode": "record_then_regression",
  "allowed_regression_percentage_points": 0.0,
  "domains": {
    "core": {
      "paths": ["backend/app/core/"],
      "target_percent": 80.0
    },
    "services": {
      "paths": ["backend/app/services/"],
      "target_percent": 75.0
    },
    "api": {
      "paths": ["backend/app/api/", "backend/app/routers/"],
      "target_percent": 70.0
    },
    "repositories": {
      "paths": ["backend/app/repositories/"],
      "target_percent": 70.0
    },
    "runtime": {
      "paths": [
        "backend/app/core/runtime_",
        "backend/app/core/operational_",
        "backend/app/services/runtime_",
        "backend/app/services/operational_",
        "backend/app/api/runtime_",
        "backend/app/api/operational_"
      ],
      "target_percent": 70.0
    }
  },
  "baseline": {}
}
