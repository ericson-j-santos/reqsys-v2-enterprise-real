{
  "schema_version": "1.1.0",
  "mode": "record_then_regression",
  "allowed_regression_percentage_points": 0.0,
  "domains": {
    "core": {
      "paths": ["app/core/"],
      "target_percent": 80.0
    },
    "services": {
      "paths": ["app/services/"],
      "target_percent": 75.0
    },
    "api": {
      "paths": ["app/api/", "app/routers/"],
      "target_percent": 70.0
    },
    "repositories": {
      "paths": ["app/repositories/"],
      "target_percent": 70.0
    },
    "runtime": {
      "paths": ["app/runtime/", "app/operational/"],
      "target_percent": 70.0
    }
  },
  "baseline": {}
}
