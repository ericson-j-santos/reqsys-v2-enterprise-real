# Ambiente da aplicação
# Valores aceitos para produção: production, prod ou prd
APP_ENV=development
ALLOW_DEMO_LOGIN=true

# Banco de dados — Postgres centralizado em dev/test/prod-local/CI (ADR-042/ADR-043).
# `docker compose up` ja sobe um Postgres (servico `db`) e aponta pra ele sozinho;
# a linha abaixo so importa se voce roda a API fora de Docker (uvicorn direto):
DATABASE_URL=postgresql+psycopg2://reqsys_app:reqsys_local_dev@localhost:5432/reqsys
# SQL Server (alvo formal de producao, ainda nao provisionado — ver ADR-042/README):
# DATABASE_URL=mssql+pyodbc://USUARIO:SENHA@SERVIDOR/BANCO?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
# SQLite (fallback zero-dependencia, sem Postgres instalado):
# DATABASE_URL=sqlite:///./reqsys.db

# JWT — OBRIGATORIO em prod. Gere com:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=TROQUE-POR-UM-SEGREDO-FORTE-MINIMO-32-CHARS
# Obrigatórios em produção para validação real de issuer/audience
JWT_ISSUER=reqsys-api
JWT_AUDIENCE=reqsys-frontend
JWT_EXP_MINUTES=60

# Login com conta Microsoft / Windows (Azure AD / Microsoft Entra ID)
# Necessario para habilitar o botao "Entrar com conta Microsoft" no frontend.
# Quando AZURE_TENANT_ID e AZURE_CLIENT_ID estao vazios, o login Microsoft fica
# desabilitado (GET /v1/auth/config retorna azure_enabled=false).
# Estrategia recomendada: manter este login sempre habilitado em homologacao/producao.
# Para certificado digital corporativo, prefira Microsoft Entra CBA como caminho primario.
# IMPORTANTE: no portal do Entra, registre como "SPA" o redirect URI igual a
# origem exata usada para acessar o app (ex.: http://localhost:5173,
# http://localhost:8083 ou a URL publica). Origem nao registrada => AADSTS50011.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Login hibrido com certificado digital
# Mantido desligado por padrao. Em producao, quando CERT_LOGIN_ENABLED=true,
# CERT_TRUST_STORE_PATH e obrigatorio pelo gate de boot.
# O frontend espera um agente local/Web PKI em window.ReqSysCertificateAgent
# para assinar o desafio sem enviar chave privada ao ReqSys.
# Estrategia recomendada: ativar primeiro em homologacao/piloto ICP-Brasil,
# mantendo Microsoft Entra como fallback visivel na tela de login.
CERT_LOGIN_ENABLED=false
CERT_TRUST_STORE_PATH=
CERT_ALLOWED_ISSUERS=
CERT_CHALLENGE_TTL_SECONDS=300

# Teams Bot (Azure Bot Service / Bot Framework) — App Registration DEDICADO,
# separado do AZURE_CLIENT_ID acima. Usado pelo canal "bot" do Teams Messaging
# Gateway para enviar mensagem 1:1 proativa sem login interativo por sessao.
# Exige um Azure Bot resource real (ver docs/architecture/teams-messaging-gateway.md).
TEAMS_BOT_APP_ID=
TEAMS_BOT_APP_TENANT_ID=
TEAMS_BOT_SECRET=

# Teams "Chat with Flow bot" (Power Automate) — URL do trigger "When a Teams
# webhook request is received" de um flow com a acao "Post a message in a chat
# or channel" (Post as: Flow bot, Post in: Chat with Flow bot, Recipient
# dinamico). Alternativa ao canal bot que NAO exige Azure Bot Service nem
# assinatura Azure — ver docs/architecture/teams-messaging-gateway.md.
# Usada apenas como fallback de UM dono sem redundancia; o caminho recomendado
# em producao e cadastrar multiplos donos via API (POST /v1/teams-gateway/flow-bot/owners)
# para failover automatico quando um flow for desligado (dono de ferias/licenca/etc).
TEAMS_FLOW_BOT_WEBHOOK_URL=

REQSYS_VAULT_SERVICE_NAME=mvp-intelligence-vault
# Token para acesso service-to-service ao cofre (POST /v1/cofre/resolver)
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
VAULT_API_TOKEN=
BACKEND_PORT=8211
FRONTEND_PORT=5173
GATEWAY_PORT=8083
VITE_API_URL=/api
ENABLE_GITHUB_REDMINE_IMPORT=true
GITHUB_TOKEN=
ENABLE_FIGMA_GITHUB_SYNC=true
FIGMA_ACCESS_TOKEN=
FIGMA_WEBHOOK_SECRET=
FIGMA_DEFAULT_FILE_KEY=
FIGMA_GITHUB_DEFAULT_REPO=
REDMINE_BASE_URL=
REDMINE_API_KEY=
REDMINE_PROJECT_ID=
SSRS_BASE_URL=
SSRS_REQUIRE_HTTPS=true
SSRS_REPORTS_PATH=ReqSys
SSRS_REPORT_NAMES=AtvIndividual,Cracha,CracháAula2,RelatorioDetalhado,RelatorioDetalhadoAula2
# Knowledge Base interno — caminho do SQLite dentro do container
KB_DB_PATH=/data/kb.db


# Gemini IA — provider primário (gemini-2.0-flash: 15 req/min, 1500 req/dia)
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq IA — fallback automático quando Gemini esgotar cota (30 req/min, 14.400 req/dia)
# Obtenha GRÁTIS em: https://console.groq.com (sem cartão de crédito)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Specs SDD (my-first-spec-project)
# Caminho absoluto ou relativo a raiz do reqsys
SDD_SPECS_PATH=../../my-first-spec-project/.sdd
