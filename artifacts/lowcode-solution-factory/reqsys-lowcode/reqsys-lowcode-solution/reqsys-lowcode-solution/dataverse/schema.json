{
  "tables": [
    {
      "logical_name": "reqsys_demanda",
      "display_name": "Demandas",
      "description": "Entrada governada de demandas, ideias e solicitacoes.",
      "ownership": "UserOrTeam",
      "auditing_enabled": true,
      "change_tracking_enabled": true,
      "columns": [
        {
          "name": "reqsys_codigo",
          "type": "text",
          "required": true,
          "max_length": 80,
          "display_name": "Codigo"
        },
        {
          "name": "reqsys_titulo",
          "type": "text",
          "required": true,
          "max_length": 250,
          "display_name": "Titulo"
        },
        {
          "name": "reqsys_status",
          "type": "choice",
          "required": true,
          "display_name": "Status"
        },
        {
          "name": "reqsys_prioridade",
          "type": "choice",
          "required": false,
          "display_name": "Prioridade"
        },
        {
          "name": "reqsys_origem",
          "type": "choice",
          "display_name": "Origem"
        },
        {
          "name": "reqsys_solicitante",
          "type": "lookup",
          "target": "systemuser",
          "display_name": "Solicitante"
        },
        {
          "name": "reqsys_resultado_esperado",
          "type": "multiline_text",
          "display_name": "Resultado esperado"
        },
        {
          "name": "reqsys_score_priorizacao",
          "type": "whole_number",
          "display_name": "Score de priorizacao"
        }
      ],
      "views": [
        {
          "name": "Ativos",
          "filter": "reqsys_status ne \"arquivado\""
        },
        {
          "name": "Pendentes de aprovacao",
          "filter": "reqsys_status eq \"em_aprovacao\""
        },
        {
          "name": "Risco alto",
          "filter": "reqsys_prioridade eq \"alta\""
        }
      ],
      "forms": [
        {
          "name": "Principal",
          "type": "main"
        },
        {
          "name": "Rapido",
          "type": "quick_create"
