{
    "name": "reqsys-enterprise-frontend",
    "version": "3.1.0",
    "scripts": {
        "dev": "vite --host 0.0.0.0",
        "build": "vite build",
        "test": "vitest run",
        "preview": "vite preview --host 0.0.0.0",
        "test:unit": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:stable": "node scripts/run-e2e-safe.js --reporter=line",
        "validate:design-tokens": "node scripts/validate-design-tokens.mjs",
        "quality:design-system": "npm run validate:design-tokens && npm run build"
    },
    "dependencies": {
        "@azure/msal-browser": "^5.12.0",
        "@mdi/font": "latest",
        "@vitejs/plugin-vue": "latest",
        "axios": "latest",
        "mermaid": "latest",
        "pinia": "latest",
        "vite": "latest",
        "vue": "latest",
        "vue-router": "latest",
        "vuetify": "latest"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@vitest/coverage-v8": "^4.1.8",
        "@vue/test-utils": "^2.4.11",
        "jsdom": "^29.1.1",
        "vitest": "^4.1.8"
    }
}
