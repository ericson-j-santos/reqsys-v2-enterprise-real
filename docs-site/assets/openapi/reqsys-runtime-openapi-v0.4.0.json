{
  "openapi": "3.0.3",
  "info": {
    "title": "ReqSys Runtime API",
    "version": "0.4.0",
    "description": "Contrato versionado para runtime ReqSys com prática Power Automate GET/POST e workflow assíncrono com fila, worker e httpx."
  },
  "servers": [
    {
      "url": "https://reqsys-api.fly.dev",
      "description": "Ambiente público DEV/API"
    }
  ],
  "tags": [
    {
      "name": "runtime",
      "description": "Endpoints operacionais do runtime"
    },
    {
      "name": "requisitos",
      "description": "Endpoints mockados para prática GET/POST de requisitos"
    },
    {
      "name": "jobs",
      "description": "Workflow assíncrono de jobs, fila e processamento via worker/httpx"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["runtime"],
        "summary": "Health check básico",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "API operacional",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/HealthResponse"}
              }
            }
          }
        }
      }
    },
    "/api/runtime/health": {
      "get": {
        "tags": ["runtime"],
        "summary": "Health check runtime",
        "operationId": "getRuntimeHealth",
        "responses": {
          "200": {
            "description": "Runtime operacional",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/RuntimeHealthResponse"}
              }
            }
          }
        }
      }
    },
    "/api/requisitos/{id}": {
      "get": {
        "tags": ["requisitos"],
        "summary": "Consultar requisito mockado",
        "operationId": "getRequisitoById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Identificador do requisito",
            "schema": {"type": "string", "example": "REQ-001"}
          }
        ],
        "responses": {
          "200": {
            "description": "Requisito encontrado",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RequisitoResponse"}}}
          },
          "404": {
            "description": "Requisito não encontrado",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}
          }
        }
      }
    },
    "/api/requisitos": {
      "get": {
        "tags": ["requisitos"],
        "summary": "Listar requisitos mockados",
        "operationId": "listRequisitos",
        "responses": {
          "200": {
            "description": "Lista de requisitos",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RequisitoListResponse"}}}
          }
        }
      },
      "post": {
        "tags": ["requisitos"],
        "summary": "Receber requisito mockado",
        "operationId": "postRequisito",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RequisitoCreateRequest"}}}
        },
        "responses": {
          "201": {
            "description": "Requisito recebido",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RequisitoCreateResponse"}}}
          },
          "400": {
            "description": "Payload inválido",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}
          }
        }
      }
    },
    "/api/jobs": {
      "post": {
        "tags": ["jobs"],
        "summary": "Criar job assíncrono para integração externa",
        "operationId": "postAsyncJob",
        "description": "Recebe um payload, persiste o job, enfileira o processamento e retorna 202 Accepted sem aguardar a API externa.",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AsyncJobCreateRequest"}}}
        },
        "responses": {
          "202": {
            "description": "Job recebido e enfileirado",
            "headers": {
              "Location": {
                "description": "URL relativa para consulta do status do job",
                "schema": {"type": "string", "example": "/api/jobs/JOB-20260628-0001"}
              }
            },
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AsyncJobAcceptedResponse"}}}
          },
          "400": {
            "description": "Payload inválido",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}
          }
        }
      }
    },
    "/api/jobs/{job_id}": {
      "get": {
        "tags": ["jobs"],
        "summary": "Consultar status de job assíncrono",
        "operationId": "getAsyncJobStatus",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string", "example": "JOB-20260628-0001"}
          }
        ],
        "responses": {
          "200": {
            "description": "Status atual do job",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AsyncJobStatusResponse"}}}
          },
          "404": {
            "description": "Job não encontrado",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}
          }
        }
      }
    },
    "/api/runtime/dashboard": {
      "get": {
        "tags": ["runtime"],
        "summary": "Dashboard operacional do runtime",
        "operationId": "getRuntimeDashboard",
        "responses": {
          "200": {
            "description": "Snapshot do dashboard runtime",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RuntimeDashboardResponse"}}}
          }
        }
      }
    },
    "/api/runtime/analytics": {
      "get": {
        "tags": ["runtime"],
        "summary": "Analytics operacional do runtime",
        "operationId": "getRuntimeAnalytics",
        "responses": {
          "200": {
            "description": "Métricas e telemetria operacional",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RuntimeAnalyticsResponse"}}}
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {"type": "string", "example": "ok"},
          "timestamp": {"type": "string", "format": "date-time"}
        }
      },
      "RuntimeHealthResponse": {
        "type": "object",
        "required": ["status", "correlation_id"],
        "properties": {
          "status": {"type": "string", "example": "operational"},
          "service": {"type": "string", "example": "reqsys-api"},
          "correlation_id": {"type": "string", "example": "reqsys-runtime-0001"}
        }
      },
      "Requisito": {
        "type": "object",
        "required": ["id", "titulo", "tipo", "status", "prioridade", "origem", "metadata"],
        "properties": {
          "id": {"type": "string", "example": "REQ-001"},
          "titulo": {"type": "string", "example": "Registrar requisito via fluxo automatizado"},
          "descricao": {"type": "string", "example": "Fluxo de prática para integração Power Automate."},
          "tipo": {"type": "string", "enum": ["funcional", "nao_funcional", "regra_negocio", "restricao"]},
          "status": {"type": "string", "enum": ["rascunho", "validado", "aprovado", "rejeitado"]},
          "prioridade": {"type": "string", "enum": ["baixa", "media", "alta", "critica"]},
          "origem": {"type": "string", "example": "power_automate"},
          "metadata": {"$ref": "#/components/schemas/Metadata"}
        }
      },
      "RequisitoResponse": {
        "allOf": [
          {"$ref": "#/components/schemas/Requisito"},
          {"type": "object", "description": "Resposta envelopeada de consulta de requisito"}
        ]
      },
      "RequisitoCreateResponse": {
        "type": "object",
        "required": ["id", "titulo", "status", "metadata"],
        "properties": {
          "id": {"type": "string", "example": "REQ-001"},
          "titulo": {"type": "string"},
          "status": {"type": "string", "enum": ["rascunho", "validado", "aprovado", "rejeitado"]},
          "metadata": {"$ref": "#/components/schemas/Metadata"}
        }
      },
      "RequisitoListResponse": {
        "type": "object",
        "required": ["schema_version", "items", "total"],
        "properties": {
          "schema_version": {"type": "string", "example": "1.0.0"},
          "items": {"type": "array", "items": {"$ref": "#/components/schemas/Requisito"}},
          "total": {"type": "integer", "minimum": 0}
        }
      },
      "AsyncJobCreateRequest": {
        "type": "object",
        "required": ["origem", "tipo_operacao", "destino", "payload"],
        "properties": {
          "origem": {"type": "string", "example": "power_automate"},
          "tipo_operacao": {"type": "string", "enum": ["enviar_resposta", "sincronizar_requisito", "notificar_status"], "example": "enviar_resposta"},
          "destino": {"type": "string", "example": "reqsys_runtime"},
          "payload": {
            "type": "object",
            "additionalProperties": true,
            "example": {"requisito_id": "REQ-001", "status": "aprovado", "comentario": "Validado pela área de negócio"}
          },
          "metadata": {"$ref": "#/components/schemas/MetadataEntrada"}
        }
      },
      "AsyncJobAcceptedResponse": {
        "type": "object",
        "required": ["job_id", "status", "correlation_id", "status_url"],
        "properties": {
          "job_id": {"type": "string", "example": "JOB-20260628-0001"},
          "status": {"type": "string", "enum": ["queued"], "example": "queued"},
          "correlation_id": {"type": "string", "example": "reqsys-job-0001"},
          "status_url": {"type": "string", "example": "/api/jobs/JOB-20260628-0001"},
          "message": {"type": "string", "example": "Processamento recebido e enfileirado."}
        }
      },
      "AsyncJobStatusResponse": {
        "type": "object",
        "required": ["job_id", "status", "correlation_id", "created_at", "updated_at"],
        "properties": {
          "job_id": {"type": "string", "example": "JOB-20260628-0001"},
          "status": {"type": "string", "enum": ["queued", "processing", "completed", "failed", "retrying", "dead_letter"]},
          "correlation_id": {"type": "string", "example": "reqsys-job-0001"},
          "tentativas": {"type": "integer", "minimum": 0, "example": 1},
          "max_tentativas": {"type": "integer", "minimum": 1, "example": 3},
          "created_at": {"type": "string", "format": "date-time"},
          "updated_at": {"type": "string", "format": "date-time"},
          "last_error": {"type": "string", "nullable": true},
          "resultado": {"type": "object", "nullable": true, "additionalProperties": true}
        }
      },
      "RuntimeDashboardResponse": {
        "type": "object",
        "required": ["status", "correlation_id"],
        "properties": {
          "status": {"type": "string", "example": "operational"},
          "service": {"type": "string", "example": "reqsys-api"},
          "correlation_id": {"type": "string"},
          "readiness": {"type": "object"},
          "observability": {"type": "object"}
        }
      },
      "RuntimeAnalyticsResponse": {
        "type": "object",
        "required": ["correlation_id"],
        "properties": {
          "correlation_id": {"type": "string"},
          "operational_telemetry": {"type": "object"},
          "feature_metrics": {"type": "object"},
          "queue_metrics": {
            "type": "object",
            "properties": {
              "queued": {"type": "integer"},
              "processing": {"type": "integer"},
              "completed": {"type": "integer"},
              "failed": {"type": "integer"},
              "dead_letter": {"type": "integer"}
            }
          }
        }
      },
      "RequisitoCreateRequest": {
        "type": "object",
        "required": ["titulo", "descricao", "tipo", "prioridade", "origem"],
        "properties": {
          "titulo": {"type": "string", "minLength": 3, "example": "Registrar requisito via Power Automate"},
          "descricao": {"type": "string", "minLength": 10, "example": "Fluxo POST para praticar estrutura de dados."},
          "tipo": {"type": "string", "enum": ["funcional", "nao_funcional", "regra_negocio", "restricao"], "example": "funcional"},
          "prioridade": {"type": "string", "enum": ["baixa", "media", "alta", "critica"], "example": "media"},
          "origem": {"type": "string", "example": "power_automate"},
          "metadata": {"$ref": "#/components/schemas/MetadataEntrada"}
        }
      },
      "Metadata": {
        "type": "object",
        "required": ["versao_contrato", "correlation_id"],
        "properties": {
          "versao_contrato": {"type": "string", "example": "0.4.0"},
          "correlation_id": {"type": "string", "example": "reqsys-demo-0001"}
        }
      },
      "MetadataEntrada": {
        "type": "object",
        "properties": {
          "versao_contrato": {"type": "string", "example": "0.4.0"},
          "correlation_id": {"type": "string", "example": "power-automate-0001"}
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["erro", "correlation_id"],
        "properties": {
          "erro": {"type": "string", "example": "payload_invalido"},
          "mensagem": {"type": "string", "example": "Campos obrigatórios ausentes ou inválidos."},
          "correlation_id": {"type": "string", "example": "reqsys-error-0001"}
        }
      }
    }
  }
}
