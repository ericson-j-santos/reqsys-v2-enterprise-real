    {
      "name": "Consultar Requisito Mockado",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "x-correlation-id",
            "value": "{{correlationId}}"
