      "name": "Runtime Health",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "x-correlation-id",
            "value": "{{correlationId}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/runtime/health",
          "host": ["{{baseUrl}}"],
          "path": ["api", "runtime", "health"]
        },
        "description": "Verifica saúde operacional do runtime."
      }
    },
    {
      "name": "Runtime Dashboard",
      "request": {
        "method": "GET",
