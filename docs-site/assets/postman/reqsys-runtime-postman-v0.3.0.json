        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Registrar requisito via Postman\",\n  \"descricao\": \"Fluxo de recebimento POST para praticar estrutura de dados.\",\n  \"tipo\": \"funcional\",\n  \"prioridade\": \"media\",\n  \"origem\": \"postman\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/requisitos",
          "host": ["{{baseUrl}}"],
          "path": ["api", "requisitos"]
        },
        "description": "Envia requisito mockado conforme contrato OpenAPI v0.3.0."
