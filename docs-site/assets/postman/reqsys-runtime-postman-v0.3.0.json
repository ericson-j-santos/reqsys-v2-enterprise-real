          "path": ["api", "requisitos", "REQ-001"]
        },
        "description": "Consulta requisito mockado por identificador."
      }
    },
    {
      "name": "Criar Requisito Mockado",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
