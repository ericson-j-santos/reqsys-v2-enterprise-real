{
  "schema_version": "1.1.0",
  "strategy": "fly-enterprise-sync",
  "canonical_environments": ["dev", "hml", "prod"],
  "promotion_order": ["dev", "hml", "prod"],
  "environment_aliases": {
    "hml": ["staging", "stg"]
  },
  "environments": {
    "dev": {
      "fly_config": "backend/fly.dev.toml",
      "backend_fly_config": "backend/fly.dev.toml",
      "frontend_fly_config": "frontend/fly.dev.toml",
      "api_app": "reqsys-api-dev",
      "frontend_app": "reqsys-app-dev",
      "api_url": "https://reqsys-api-dev.fly.dev",
      "frontend_url": "https://reqsys-app-dev.fly.dev",
      "duckdns_url": "https://tieridev.duckdns.org",
      "app_env": "development",
      "volume": "reqsys_data_dev",
      "approval_required": false,
      "min_machines_running": 1,
      "smoke_endpoints": [
        "/health",
        "/api/runtime/health",
        "/api/runtime/readiness",
        "/api/runtime/liveness"
      ],
      "required_secret_names": ["JWT_SECRET", "JWT_ISSUER", "JWT_AUDIENCE"]
    },
    "hml": {
      "fly_config": "backend/fly.staging.toml",
      "backend_fly_config": "backend/fly.staging.toml",
      "frontend_fly_config": "frontend/fly.staging.toml",
      "api_app": "reqsys-api-stg",
      "frontend_app": "reqsys-app-stg",
      "api_url": "https://reqsys-api-stg.fly.dev",
      "frontend_url": "https://reqsys-app-stg.fly.dev",
      "duckdns_url": "https://tierin.duckdns.org",
      "app_env": "staging",
      "volume": "reqsys_data_stg",
      "approval_required": true,
      "min_machines_running": 1,
      "smoke_endpoints": [
        "/health",
        "/api/runtime/health",
        "/api/runtime/readiness",
        "/api/runtime/liveness"
      ],
      "required_secret_names": ["JWT_SECRET", "JWT_ISSUER", "JWT_AUDIENCE", "AZURE_TENANT_ID", "AZURE_CLIENT_ID"]
    },
    "prod": {
      "fly_config": "backend/fly.toml",
      "backend_fly_config": "backend/fly.toml",
      "frontend_fly_config": "frontend/fly.toml",
      "api_app": "reqsys-api",
      "frontend_app": "reqsys-app",
      "api_url": "https://reqsys-api.fly.dev",
      "frontend_url": "https://reqsys-app.fly.dev",
      "duckdns_url": "https://tieriprod.duckdns.org",
      "app_env": "production",
      "volume": "reqsys_data",
      "approval_required": true,
      "min_machines_running": 1,
      "smoke_endpoints": [
        "/health",
        "/api/runtime/health",
        "/api/runtime/readiness",
        "/api/runtime/liveness",
        "/api/runtime/metrics"
      ],
      "required_secret_names": ["JWT_SECRET", "JWT_ISSUER", "JWT_AUDIENCE", "AZURE_TENANT_ID", "AZURE_CLIENT_ID"]
    }
  },
  "forbidden_versioned_secret_patterns": ["JWT_SECRET", "AZURE_CLIENT_SECRET", "PASSWORD", "TOKEN", "PRIVATE_KEY"],
  "drift_evidence": {
    "required_runtime_fields": ["commit_sha", "version", "environment", "correlation_id"],
    "artifact_name": "fly-enterprise-sync-evidence"
  }
}
