# ReqSys Codex Local — exemplo de configuração
# Não inserir secrets neste arquivo.

CODEX_LOCAL_PROVIDER=ollama
CODEX_OLLAMA_BASE_URL=http://localhost:11434

# Modelo principal para codificação
CODEX_MODEL_PRIMARY=qwen2.5-coder:7b

# Fallbacks locais
CODEX_MODEL_FALLBACK_1=deepseek-coder:6.7b
CODEX_MODEL_FALLBACK_2=codellama:7b

# RAG opcional
CODEX_RAG_ENABLED=false
CODEX_QDRANT_URL=http://localhost:6333
CODEX_QDRANT_COLLECTION=reqsys_codex_context

# Governança
CODEX_AUDIT_ENABLED=true
CODEX_REQUIRE_CORRELATION_ID=true
CODEX_ALLOW_SHELL_EXECUTION=false
CODEX_ALLOW_PRODUCTION_TARGET=false
CODEX_MASK_SENSITIVE_DATA=true
