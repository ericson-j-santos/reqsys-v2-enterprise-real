# ReqSys Codex Local — exemplo de configuração
# Não inserir secrets neste arquivo.

# Provider canônico local recomendado para o Codex Local/Online no ReqSys.
# Use `ollama_gateway` quando houver o ReqSys Ollama Local Gateway rodando no PC servidor.
CODEX_LOCAL_PROVIDER=ollama_gateway

# Acesso direto ao Ollama nativo. Útil para MVP local, mas não recomendado como integração final.
CODEX_OLLAMA_BASE_URL=http://localhost:11434
CODEX_OLLAMA_MODEL=qwen2.5-coder:7b

# Gateway local governado. Deve apontar para o PC/servidor onde o gateway está instalado.
CODEX_OLLAMA_GATEWAY_URL=http://localhost:8008
CODEX_OLLAMA_GATEWAY_API_KEY=
CODEX_OLLAMA_GATEWAY_MODEL=qwen2.5-coder:7b
CODEX_OLLAMA_GATEWAY_TIMEOUT_SECONDS=60

# Modelo principal para codificação
CODEX_MODEL_PRIMARY=qwen2.5-coder:7b

# Fallbacks locais
CODEX_MODEL_FALLBACK_1=deepseek-coder:6.7b
CODEX_MODEL_FALLBACK_2=codellama:7b

# RAG opcional
CODEX_RAG_ENABLED=false
CODEX_QDRANT_URL=http://localhost:6333
CODEX_QDRANT_COLLECTION=reqsys_codex_context

# Governança
CODEX_AUDIT_ENABLED=true
CODEX_REQUIRE_CORRELATION_ID=true
CODEX_ALLOW_SHELL_EXECUTION=false
CODEX_ALLOW_PRODUCTION_TARGET=false
CODEX_MASK_SENSITIVE_DATA=true
