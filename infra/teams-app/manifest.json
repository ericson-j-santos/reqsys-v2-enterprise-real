{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.16/MicrosoftTeams.schema.json",
  "manifestVersion": "1.16",
  "version": "1.0.0",
  "id": "00000000-0000-0000-0000-000000000000",
  "developer": {
    "name": "ReqSys",
    "websiteUrl": "https://reqsys-api.fly.dev",
    "privacyUrl": "https://reqsys-api.fly.dev/privacy",
    "termsOfUseUrl": "https://reqsys-api.fly.dev/terms"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "name": {
    "short": "ReqSys Teams Gateway",
    "full": "ReqSys Teams Messaging Gateway"
  },
  "description": {
    "short": "Envia notificacoes do ReqSys diretamente no seu Teams.",
    "full": "Bot do ReqSys usado pelo Teams Messaging Gateway para enviar mensagens proativas 1:1 sem exigir login interativo a cada envio."
  },
  "accentColor": "#5B3CC4",
  "bots": [
    {
      "botId": "${{TEAMS_BOT_APP_ID}}",
      "scopes": ["personal"],
      "supportsFiles": false,
      "isNotificationOnly": true
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["reqsys-api.fly.dev"]
}
