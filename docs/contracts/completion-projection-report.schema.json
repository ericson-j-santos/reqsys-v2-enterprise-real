{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reqsys.local/contracts/completion-projection-report.schema.json",
  "title": "ReqSys Completion Projection Report Artifact",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "generated_at", "repository", "run_id", "event_name", "reference_time", "overall_completion_percent", "overall_maturity_percent", "average_gap_pp", "status", "mvp_probability_percent", "enterprise_consolidation_probability_percent", "current_state", "velocity", "completion_indicators", "remaining_gaps", "projection_conservative", "projection_accelerated", "primary_bottlenecks", "risk_index", "trends", "probabilities", "acceleration_levers", "executive_reading", "mode"],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "repository": { "type": "string" },
    "run_id": { "type": "string" },
    "event_name": { "type": "string" },
    "reference_time": { "type": "string" },
    "overall_completion_percent": { "type": "number", "minimum": 0, "maximum": 100 },
    "overall_maturity_percent": { "type": "number", "minimum": 0, "maximum": 100 },
    "average_gap_pp": { "type": "number", "minimum": 0 },
    "status": { "type": "string", "enum": ["consolidado", "em_consolidacao", "em_evolucao"] },
    "mvp_probability_percent": { "type": "number", "minimum": 0, "maximum": 100 },
    "enterprise_consolidation_probability_percent": { "type": "number", "minimum": 0, "maximum": 100 },
    "current_state": { "type": "array", "items": { "type": "object" } },
    "velocity": { "type": "object" },
    "completion_indicators": { "type": "array", "items": { "type": "object" } },
    "remaining_gaps": { "type": "array", "items": { "type": "object" } },
    "projection_conservative": { "type": "array", "items": { "type": "object" } },
    "projection_accelerated": { "type": "array", "items": { "type": "object" } },
    "primary_bottlenecks": { "type": "array", "items": { "type": "string" } },
    "risk_index": { "type": "array", "items": { "type": "object" } },
    "trends": { "type": "array", "items": { "type": "object" } },
    "probabilities": { "type": "array", "items": { "type": "object" } },
    "acceleration_levers": { "type": "array", "items": { "type": "string" } },
    "executive_reading": { "type": "object" },
    "mode": { "type": "string", "enum": ["report_only"] }
  }
}
