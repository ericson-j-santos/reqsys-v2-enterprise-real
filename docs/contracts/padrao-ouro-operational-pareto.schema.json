{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reqsys.local/contracts/padrao-ouro-operational-pareto.schema.json",
  "title": "ReqSys Padrão Ouro — Operational Pareto Index",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "repo",
    "generated_at",
    "state",
    "strategy",
    "current_score",
    "target_score",
    "gold_gap",
    "projected_score_after_recommended",
    "projected_gap_after_recommended",
    "statistical_confidence",
    "dimension_signals",
    "dimension_gaps",
    "dominant_bottleneck",
    "summary",
    "links",
    "ranked_actions",
    "runtime_dashboard_contract"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0.0", "1.1.0"] },
    "repo": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "state": { "type": "string", "enum": ["green", "yellow", "red"] },
    "strategy": { "type": "string", "const": "pareto_operational_gold_base" },
    "current_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "target_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "gold_gap": { "type": "number", "minimum": 0, "maximum": 100 },
    "projected_score_after_recommended": { "type": "number", "minimum": 0, "maximum": 100 },
    "projected_gap_after_recommended": { "type": "number", "minimum": 0, "maximum": 100 },
    "statistical_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "dimension_signals": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0, "maximum": 100 }
    },
    "dimension_gaps": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0, "maximum": 100 }
    },
    "dominant_bottleneck": {
      "type": "object",
      "required": ["dimension", "score", "gap_to_100", "share_of_trilha_d_remaining_gap"],
      "properties": {
        "dimension": { "type": "string" },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "gap_to_100": { "type": "number", "minimum": 0, "maximum": 100 },
        "share_of_trilha_d_remaining_gap": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "actions_evaluated",
        "recommended_now",
        "expected_gain_now",
        "pareto_rule",
        "next_increment"
      ],
      "properties": {
        "actions_evaluated": { "type": "integer", "minimum": 0 },
        "recommended_now": { "type": "integer", "minimum": 0 },
        "expected_gain_now": { "type": "number", "minimum": 0 },
        "pareto_rule": { "type": "string" },
        "next_increment": { "type": ["string", "null"] },
        "evidence_source": { "type": "string" },
        "consolidation_mode": { "type": "boolean" }
      }
    },
    "ranked_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "pareto_score",
          "expected_score_gain",
          "rank",
          "recommended_now"
        ],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "lane": { "type": "string" },
          "dimension": { "type": "string" },
          "current_score": { "type": "number" },
          "target_score": { "type": "number" },
          "expected_score_gain": { "type": "number", "minimum": 0 },
          "pareto_score": { "type": "number", "minimum": 0 },
          "rank": { "type": "integer", "minimum": 1 },
          "cumulative_expected_gain_pct": { "type": "number", "minimum": 0, "maximum": 100 },
          "recommended_now": { "type": "boolean" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "risk": { "type": "string", "enum": ["low", "medium", "high"] }
        }
      }
    }
  }
}
