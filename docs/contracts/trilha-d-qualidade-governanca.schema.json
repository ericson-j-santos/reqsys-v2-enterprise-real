{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reqsys.local/contracts/trilha-d-qualidade-governanca.schema.json",
  "title": "ReqSys Trilha D — Qualidade e Governança",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "trail",
    "trail_name",
    "generated_at",
    "correlation_id",
    "repository",
    "run_id",
    "parallelizable",
    "dimensions_total",
    "state",
    "decision",
    "average_score",
    "min_score",
    "max_score",
    "blockers",
    "dimensions",
    "recommended_actions",
    "mode"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "trail": { "type": "string", "const": "D" },
    "trail_name": { "type": "string", "const": "Qualidade e Governança" },
    "generated_at": { "type": "string", "format": "date-time" },
    "correlation_id": { "type": "string", "minLength": 1 },
    "repository": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "parallelizable": { "type": "boolean", "const": true },
    "dimensions_total": { "type": "integer", "minimum": 1, "maximum": 6 },
    "state": { "type": "string", "enum": ["passed", "warning", "failed", "skipped"] },
    "decision": { "type": "string", "minLength": 1 },
    "average_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "min_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "max_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["dimension", "status", "score", "duration_seconds", "summary", "details", "blockers", "recommendations"],
        "properties": {
          "dimension": {
            "type": "string",
            "enum": ["tests", "coverage", "mutation", "contract", "schema", "ci-watch"]
          },
          "status": { "type": "string", "enum": ["passed", "warning", "failed", "skipped"] },
          "score": { "type": "number", "minimum": 0, "maximum": 100 },
          "duration_seconds": { "type": "number", "minimum": 0 },
          "summary": { "type": "string" },
          "details": { "type": "object" },
          "blockers": { "type": "array", "items": { "type": "string" } },
          "recommendations": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "recommended_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["priority", "action", "detail"],
        "properties": {
          "priority": { "type": "string" },
          "action": { "type": "string" },
          "detail": { "type": "string" }
        }
      }
    },
    "mode": { "type": "string", "enum": ["report_only"] }
  }
}
