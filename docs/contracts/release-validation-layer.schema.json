{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reqsys.local/contracts/release-validation-layer.schema.json",
  "title": "ReqSys Release Validation Layer Artifact",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "validation_layer_version",
    "correlation_id",
    "generated_at",
    "repository",
    "branch",
    "run_id",
    "event_name",
    "mode",
    "release_readiness_score",
    "readiness",
    "risk",
    "operational_state",
    "quality_gates",
    "ci_semantic_validation",
    "release_evidence",
    "blockers",
    "warnings",
    "recommended_actions",
    "executive_dashboard",
    "guardrails"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "validation_layer_version": { "type": "string" },
    "correlation_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "repository": { "type": "string" },
    "branch": { "type": "string" },
    "run_id": { "type": "string" },
    "event_name": { "type": "string" },
    "mode": { "type": "string", "enum": ["report_only"] },
    "release_readiness_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "readiness": {
      "type": "string",
      "enum": ["ready", "ready_with_observation", "needs_review", "blocked"]
    },
    "risk": { "type": "string", "enum": ["low", "medium_low", "medium", "high"] },
    "operational_state": { "type": "string", "enum": ["green", "yellow", "red", "unknown"] },
    "quality_gates": { "type": "array", "items": { "type": "object" } },
    "ci_semantic_validation": { "type": "object" },
    "release_evidence": { "type": "array", "items": { "type": "object" } },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "recommended_actions": { "type": "array", "items": { "type": "object" } },
    "executive_dashboard": { "type": "object" },
    "guardrails": { "type": "object" }
  }
}
