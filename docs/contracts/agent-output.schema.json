{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reqsys.local/contracts/agent-output.schema.json",
  "title": "ReqSys Agent Output Padronizado",
  "description": "Contrato de saída estruturada para agentes especializados do ecossistema ReqSys.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "correlation_id",
    "agent",
    "generated_at",
    "contexto",
    "diagnostico",
    "riscos",
    "acoes_recomendadas",
    "quick_wins",
    "proximo_incremento",
    "nivel_confianca"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1,
      "description": "Identificador de rastreabilidade ponta a ponta (UUID recomendado)."
    },
    "agent": {
      "type": "string",
      "enum": [
        "agent-arquiteto",
        "agent-backend",
        "agent-frontend",
        "agent-devops",
        "agent-qa",
        "agent-power-platform",
        "agent-sql-analytics",
        "agent-governanca",
        "agent-product-owner",
        "agent-operacional"
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "contexto": {
      "type": "object",
      "description": "Contexto analisado pelo agente (escopo, artefatos, branch, PR, etc.).",
      "additionalProperties": false,
      "properties": {
        "repositorio": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        },
        "escopo": {
          "type": "string"
        },
        "artefatos_consultados": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "diagnostico": {
      "type": "object",
      "description": "Diagnóstico estruturado específico do domínio do agente.",
      "additionalProperties": false,
      "properties": {
        "estado_atual": {
          "type": "string"
        },
        "gargalos": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "debito_tecnico": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "riscos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "descricao",
          "severidade"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "descricao": {
            "type": "string"
          },
          "severidade": {
            "type": "string",
            "enum": [
              "baixa",
              "media",
              "alta",
              "critica"
            ]
          },
          "mitigacao": {
            "type": "string"
          }
        }
      }
    },
    "acoes_recomendadas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "prioridade",
          "descricao"
        ],
        "additionalProperties": false,
        "properties": {
          "prioridade": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          },
          "descricao": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "esforco": {
            "type": "string",
            "enum": [
              "baixo",
              "medio",
              "alto"
            ]
          }
        }
      }
    },
    "quick_wins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "descricao"
        ],
        "additionalProperties": false,
        "properties": {
          "descricao": {
            "type": "string"
          },
          "impacto": {
            "type": "string"
          },
          "esforco": {
            "type": "string",
            "enum": [
              "baixo",
              "medio"
            ]
          }
        }
      }
    },
    "proximo_incremento": {
      "type": "object",
      "description": "Próximo passo natural após esta análise.",
      "additionalProperties": false,
      "properties": {
        "tipo": {
          "type": "string",
          "enum": [
            "gap_fix",
            "hotfix",
            "new_front",
            "consolidate",
            "report_only"
          ]
        },
        "descricao": {
          "type": "string"
        },
        "agente_sugerido": {
          "type": "string"
        },
        "dependencias": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "nivel_confianca": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confiança do agente na análise (0.0 a 1.0)."
    }
  },
  "runtime_validation_required": true
}
