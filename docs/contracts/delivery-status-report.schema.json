{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reqsys.local/contracts/delivery-status-report.schema.json",
  "title": "ReqSys Delivery Status Report Artifact",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "generated_at", "repository", "run_id", "event_name", "tracked_prs", "merged_prs", "merge_rate_percent", "standard_parallel_prs", "current_maturity_percent", "target_maturity_percent", "remaining_gap_pp", "status", "groups", "mode"],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "repository": { "type": "string" },
    "run_id": { "type": "string" },
    "event_name": { "type": "string" },
    "tracked_prs": { "type": "integer", "minimum": 0 },
    "merged_prs": { "type": "integer", "minimum": 0 },
    "merge_rate_percent": { "type": "number", "minimum": 0, "maximum": 100 },
    "standard_parallel_prs": { "type": "integer", "minimum": 1 },
    "current_maturity_percent": { "type": "number", "minimum": 0, "maximum": 100 },
    "target_maturity_percent": { "type": "number", "minimum": 0, "maximum": 100 },
    "remaining_gap_pp": { "type": "number" },
    "status": { "type": "string" },
    "groups": { "type": "array", "items": { "type": "object" } },
    "mode": { "type": "string", "enum": ["report_only"] }
  }
}
