{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reqsys.local/schemas/operational-health-dashboard.schema.json",
  "title": "Operational Health Dashboard",
  "type": "object",
  "required": ["status", "mode", "guardrails"],
  "properties": {
    "status": {
      "type": "string",
      "const": "OPERATIONAL_HEALTH_DASHBOARD_READY"
    },
    "mode": {
      "type": "string",
      "const": "review_only"
    },
    "guardrails": {
      "type": "object",
      "required": ["deployment", "production_write", "permission_update", "automated_merge"],
      "properties": {
        "deployment": { "type": "string", "const": "not_performed" },
        "production_write": { "type": "string", "const": "not_performed" },
        "permission_update": { "type": "string", "const": "not_performed" },
        "automated_merge": { "type": "string", "const": "not_performed" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
