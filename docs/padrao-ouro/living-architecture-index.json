      "schema": "docs/contracts/coordenador-status.schema.json",
      "domain": "governance",
      "producers": ["coordenador-status-consolidator.yml"],
      "consumers": ["agent-increment-gate", "AGENTS.md"]
    },
    {
      "id": "operational-observability-hub",
      "schema": "docs/contracts/operational-json-artifact.schema.json",
      "domain": "observability",
      "producers": ["operational-observability-hub.yml"],
      "consumers": ["coordenador-status-consolidator", "ops-dashboard", "operational-alert-intelligence"]
    },
    {
      "id": "runtime-validation-snapshot",
      "schema": "docs/contracts/runtime-validation-snapshot.schema.json",
