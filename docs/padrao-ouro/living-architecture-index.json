  "operational_focus": {
    "mode": "consolidate",
    "reason": "state_yellow bloqueia novas frentes; foco em estabilizacao, evidencia e rastreabilidade",
    "purpose": "Priorizar mudanças pequenas e rastreáveis que fortaleçam governança, rastreabilidade, CI, segurança e documentação acionável.",
    "priorities": [
      { "id": "P0", "area": "Governança de incremento", "minimum_evidence": "Agent Increment Gate, status do coordenador ou justificativa explícita de escopo fechado", "done_when": "Sem nova frente bloqueada, duplicada ou sem dono." },
      { "id": "P1", "area": "Rastreabilidade viva", "minimum_evidence": "Índice, contrato, ADR, runbook ou grafo de evidência atualizado", "done_when": "Owner, workflow, artifact e rollback localizáveis por humanos e agentes." },
      { "id": "P2", "area": "CI e qualidade sustentável", "minimum_evidence": "Teste, lint, schema validation ou workflow report-only aplicável", "done_when": "Falha reproduzível vira evidência; sucesso vira artifact rastreável." },
      { "id": "P3", "area": "Segurança operacional", "minimum_evidence": "Gates de produção, segredos, CORS, JWT, auditoria ou correlation ID revisados quando tocados", "done_when": "Nenhum segredo, PII ou relaxamento produtivo entra no PR." },
      { "id": "P4", "area": "Documentação acionável", "minimum_evidence": "Playbook/runbook curto com comando validado ou pendência explícita", "done_when": "O próximo agente sabe o próximo passo sem depender de contexto de chat." }
    ],
    "consolidation_directions": [
      {
        "id": "consolidar-evidencias",
        "priority": 1,
        "direction": "Consolidar CI, gates e artifacts existentes antes de abrir novas frentes.",
        "expected_evidence": ["workflow verde", "artifact versionado", "referencia no runtime evidence graph"],
        "risk_reduced": "perda de rastreabilidade operacional"
      },
      {
        "id": "fechar-gaps-tier1",
        "priority": 2,
        "direction": "Fechar gaps documentados de arquitetura, contratos ou testes com alteracao minima.",
        "expected_evidence": ["ADR atualizado", "contrato ou schema validado", "playbook ou teste atualizado"],
        "risk_reduced": "desalinhamento entre decisao, contrato e implementacao"
      },
      {
        "id": "bloquear-novas-frentes-sem-gate",
        "priority": 3,
        "direction": "Evitar nova superficie funcional quando o Agent Increment Gate estiver bloqueado.",
        "expected_evidence": ["saida do agent_increment_gate", "pendencia registrada quando bloqueado"],
        "risk_reduced": "concorrencia de PRs e expansao de escopo sem governanca"
      }
    ],
    "pr_checklist": [
      "Confirmar o artefato Tier 1 afetado",
      "Registrar evidência programática possível",
      "Declarar fora de escopo",
      "Atualizar machine-readable quando ownership/workflow/contrato/módulo mudar",
      "Manter rollback simples"
    ],
    "consolidation": {
      "trigger": "coordenador state_yellow com new_front_allowed false",
      "allowed_increment_types": ["consolidate", "gap_fix", "hotfix"],
      "actions": [
        "fechar PRs duplicados apontando para canônico em main",
        "sincronizar índices Tier 1 antes de abrir nova frente",
        "validar JSON e comandos focados no escopo"
      ],
      "exit_criteria": "gate, artefatos Tier 1 afetados e validação focada rastreáveis no PR"
    }
  },
